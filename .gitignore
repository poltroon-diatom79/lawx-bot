# Зависимости Node.js — устанавливаются автоматически через npm install.
# ОБЯЗАТЕЛЬНО игнорировать, НИКОГДА не коммитить в репозиторий
node_modules/

# Файлы логов — генерируются в runtime, содержат данные, НЕ код.
# ВАЖНО: могут содержать чувствительную информацию
logs/
*.log
npm-debug.log*

# Системные файлы ОС — автоматически создаются macOS и Windows, НЕ относятся к проекту
.DS_Store
Thumbs.db
desktop.ini

# Директории сборки — исключаются на случай добавления build-пайплайна в будущем
dist/
build/
out/

# Временные файлы редакторов и системных процессов
*.tmp
*.temp
*.swp
*.swo
*~

# Локальные настройки IDE — у каждого разработчика СВОИ, НЕ должны быть в репозитории
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Отчёты о тестовом покрытии — генерируются при запуске тестов с флагом --coverage
coverage/
.nyc_output/

# Файлы локальных баз данных — НИКОГДА не коммитить, содержат пользовательские данные
*.sqlite
*.sqlite3
*.db

# Временные директории для сгенерированного контента — создаются в runtime
temp/
tmp/
uploads/
generated/

# Файлы переменных окружения — ВАЖНО: основной .env нужен для работы, НЕ игнорировать!
# .env
.env.local
.env.production
.env.development

# PID-файлы процессов — создаются менеджерами процессов (pm2, forever)
*.pid
